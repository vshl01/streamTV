# ----------------------------------------------------------------------------
# StreamTV environment variables
#
# The app runs fully offline with the bundled public/content.json fallback,
# so NONE of these are required for local development. Set the Contentful vars
# to switch the CMS client from the JSON fallback to the live Delivery API.
# ----------------------------------------------------------------------------

# Contentful Delivery API (REST + GraphQL). When both SPACE_ID and ACCESS_TOKEN
# are present, the CMS client fetches from Contentful instead of content.json.
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Absolute site URL used for canonical links and Open Graph metadata.
# On Vercel this is inferred from VERCEL_URL if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
